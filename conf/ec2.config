params {
    // Omica overrides these via inputData
    reads = null
    outdir = null

    // S3 references for CanFam3.1
    fasta = "s3://omica-pipeline-data/examples/CanFam3.1ref.fa"
    bed   = "s3://omica-pipeline-data/examples/panel_ensembl.bed"

    // ANNOVAR references
    annovar_home = "s3://omica-pipeline-data/examples/ANNOVAR_ref/"
    annovar_db   = "s3://omica-pipeline-data/examples/ANNOVAR_ref/"

    // Other pipeline params (unchanged)
    isec_n = "+2"
    biomart_host = "https://may2021.archive.ensembl.org"
    biomart_dataset = "clfamiliaris_gene_ensembl"
    keep_intermediates = false
}



// ---------- Global defaults ----------

process {
    beforeScript = 'source ~/miniconda3/bin/activate ngs_env'
}

process {
    conda = "$projectDir/ngs_env.yml"
}


process {
  executor     = 'local'
  cpus         = 1
  memory       = '2 GB'
  beforeScript = 'source ~/miniconda3/bin/activate ngs_env'
  // Ensure all processes use the large temp dir
  env.TMPDIR   = "/home/ec2-user/tmp"
}

// Cap total capacity of the node
executor {
  name   = 'local'
  cpus   = 12
  memory = '480 GB'
}

// ---------- Limit concurrency for sort-heavy tasks ----------
process {
  // Any process with label 'heavy_sort' will run at most N in parallel
  withLabel: 'heavy_sort' {
    maxForks = 3
  }
}

// ---------- Per-process resources (safe defaults) ----------
withName: ALIGNMENT {
  // bwa mem piped to samtools sort
  cpus   = 3
  memory = '12 GB'
}

withName: ADD_READ_GROUP {
  // picard then samtools sort
  cpus   = 3
  memory = '8 GB'
}

withName: BAM_FILTER {
  // samtools view -L + index
  cpus   = 2
  memory = '6 GB'
}

withName: MUTECT2_CALL { cpus = 4; memory = '20 GB' }
withName: VARSCAN_CALL { cpus = 2; memory = '8 GB'  }
withName: FREEBAYES_CALL { cpus = 2; memory = '8 GB' }

withName: SAMTOOLS_FLAGSTAT { cpus = 1; memory = '2 GB' }
withName: SAMTOOLS_STATS    { cpus = 1; memory = '3 GB' }
withName: BEDTOOLS_COVERAGE_HIST { cpus = 2; memory = '6 GB' }
withName: MULTIQC           { cpus = 1; memory = '2 GB' }
